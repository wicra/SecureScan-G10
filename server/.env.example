# ── Serveur ──────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Base de données ──────────────────────────────────
# Format : mysql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="mysql://root:password@localhost:3306/securescan"

# ── Auth JWT ─────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=remplace_moi_par_une_chaine_aleatoire_longue
JWT_EXPIRES_IN=7d

# ── OAuth GitHub (optionnel) ─────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/api/auth/github/callback

# ── IA (bonus) ───────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Scans ────────────────────────────────────────────
# Dossier temporaire où les repos sont clonés puis supprimés
TMP_SCAN_DIR=./tmp
